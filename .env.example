# Discord Webhook URL - tạo trong Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# League để theo dõi
LEAGUE=Standard

# Ngưỡng biến động giá (%) để gửi alert
PRICE_CHANGE_THRESHOLD=15

# Giá tối thiểu (chaos) để theo dõi - bỏ qua item rẻ
MIN_CHAOS_VALUE=700

# Thời gian giữa mỗi lần check (giây)
POLL_INTERVAL=300
